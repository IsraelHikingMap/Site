{
  "offlineFilesFolder": "/tmp/offline",
  "logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Error",
      "System.Net": "None"
    },
    "NLog": {
      "RemoveLoggerFactoryFilter": false
    }
  },
  "NLog": {
    "throwConfigExceptions": true,
    "targets": {
      "async": true,
      "error": {
        "type": "File",
        "fileName": "Logs/${shortdate}-errors.log",
        "maxArchiveFiles": 10,
        "layout": "${longdate} |${threadid:padding=3}|${level:uppercase=true:padding=-5}| ${logger} | ${message} ${exception:format=ToString}"
      },
      "site": {
        "type": "File",
        "fileName": "Logs/${shortdate}-site.log",
        "maxArchiveFiles": 10,
        "layout": "${longdate} |${threadid:padding=3}|${level:uppercase=true:padding=-5}| ${message} ${exception}"
      },
      "logconsole": {
        "type": "Console"
      }
    },
    "rules": [
      {
        "logger": "*",
        "minLevel": "Error",
        "writeTo": "error"
      },
      {
        "logger": "*",
        "minLevel": "Debug",
        "writeTo": "site"
      },
      {
        "logger": "*",
        "minLevel": "Debug",
        "writeTo": "logconsole"
      }
    ]
  }
}
