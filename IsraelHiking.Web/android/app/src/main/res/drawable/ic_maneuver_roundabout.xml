<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="48dp"
    android:height="48dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- Generalized roundabout: a large hollow ring with the road entering from the bottom and three
         exit arrows (left, top, right). Direction-neutral (used for both CW and CCW). The wide hollow
         center is left clear so the exit number can be drawn into it at runtime
         (see CarNavigation.roundaboutIcon). -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="@android:color/white"
        android:strokeWidth="2"
        android:pathData="M12,12 m-7,0 a7,7 0 1,1 14,0 a7,7 0 1,1 -14,0" />
    <!-- entry road from the bottom -->
    <path
        android:strokeColor="@android:color/white"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:pathData="M12,23 L12,19.5" />
    <!-- top exit arrow -->
    <path
        android:strokeColor="@android:color/white"
        android:strokeWidth="2"
        android:pathData="M12,4 L12,3" />
    <path
        android:fillColor="@android:color/white"
        android:pathData="M12,0.6 L14.3,3.4 L9.7,3.4 Z" />
    <!-- left exit arrow -->
    <path
        android:strokeColor="@android:color/white"
        android:strokeWidth="2"
        android:pathData="M4,12 L3,12" />
    <path
        android:fillColor="@android:color/white"
        android:pathData="M0.6,12 L3.4,9.7 L3.4,14.3 Z" />
    <!-- right exit arrow -->
    <path
        android:strokeColor="@android:color/white"
        android:strokeWidth="2"
        android:pathData="M20,12 L21,12" />
    <path
        android:fillColor="@android:color/white"
        android:pathData="M23.4,12 L20.6,9.7 L20.6,14.3 Z" />
</vector>
